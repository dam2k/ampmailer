{
    "name": "dam2k/ampmailer",
    "description": "Small AMPHP v3 mailer with MIME rendering, SMTP transport, retry, and rate limiting.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Dam2k\\AmpMailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dam2k\\AmpMailer\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "amphp/amp": "^3.0",
        "amphp/byte-stream": "^2.0",
        "amphp/socket": "^2.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
